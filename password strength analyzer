import re

def check_password_strength(password):
    """
    Evaluates the strength of a given password and returns a score,
    a verbal rating, and specific feedback for improvement.
    """
    # 1. Initialize scoring and feedback
    score = 0
    feedback = []
    
    # 2. Define minimum criteria thresholds
    has_upper = bool(re.search(r'[A-Z]', password))
    has_lower = bool(re.search(r'[a-z]', password))
    has_digit = bool(re.search(r'\d', password))
    has_special = bool(re.search(r'[!@#$%^&*(),.?":{}|<>]', password))
    
    # 3. Check individual criteria and calculate score
    if len(password) >= 12:
        score += 2
    elif len(password) >= 8:
        score += 1
    else:
        feedback.append("Increase total length to at least 8 characters (12+ is best).")
        
    if has_upper:
        score += 1
    else:
        feedback.append("Add at least one uppercase letter (A-Z).")
        
    if has_lower:
        score += 1
    else:
        feedback.append("Add at least one lowercase letter (a-z).")
        
    if has_digit:
        score += 1
    else:
        feedback.append("Add at least one numerical digit (0-9).")
        
    if has_special:
        score += 1
    else:
        feedback.append("Add at least one special character (e.g., !, @, #, $, %).")

    # 4. Determine final rating based on the score (Max score = 6)
    if score >= 5:
        rating = "Strong 🟢"
    elif 3 <= score < 5:
        rating = "Medium 🟡"
    else:
        rating = "Weak 🔴"
        
    return rating, feedback


# Interactive User Execution Block
if __name__ == "__main__":
    print("--- Python Password Strength Checker ---")
    user_password = input("Enter a password to test: ").strip()
    
    # Run the validation
    rating, improvements = check_password_strength(user_password)
    
    # Display the results
    print(f"\nPassword Rating: {rating}")
    
    if improvements:
        print("\nSuggestions to make it stronger:")
        for suggestion in improvements:
            print(f" - {suggestion}")
    else:
        print("Great job! Your password meets all core safety guidelines.")

